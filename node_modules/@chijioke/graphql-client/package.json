{
    "name": "@chijioke/graphql-client",
    "version": "0.0.7",
    "description": "Graphql client for typescript",
    "keywords": [
        "graphql",
        "sdk",
        "typescript"
    ],
    "author": "Agu Chijioke <chokey2nv@gmail.com>",
    "license": "MIT",
    "main": "dist/index.cjs.js",
    "module": "dist/index.esm.js",
    "react-native": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "react-native": "./dist/index.esm.js",
            "import": "./dist/index.esm.js",
            "require": "./dist/index.cjs.js",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsup src/index.ts --dts --format cjs,esm --out-dir dist",
        "prepublishOnly": "yarn build",
        "lint": "eslint src --ext .ts",
        "test": "vitest run",
        "test:run": "vitest run --reporter=verbose",
        "test:config": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@vitest/coverage-c8": "^0.33.0",
        "@vitest/ui": "^3.2.4",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.0",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4"
    }
}
